{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2021",
		"module": "ES2022",
		"moduleResolution": "node",
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["bun-types"],
		"noImplicitReturns": true
	},
	"include": ["src/**/*", "tests/**/*"],
	"exclude": ["node_modules"]
}
