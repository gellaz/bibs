{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2021",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"jsx": "react-jsx", // only for type-checking @bibs/emails' .tsx export — the API itself has no JSX
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["bun-types"],
		"noImplicitReturns": true
	},
	"include": ["src/**/*", "tests/**/*"],
	"exclude": ["node_modules"]
}
