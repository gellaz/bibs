{
	"name": "@bibs/api",
	"version": "1.0.50",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target bun",
		"test": "bun test",
		"test:unit": "bun test tests/unit",
		"test:integration": "bun test tests/integration --timeout 180000",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:clean": "rm -rf src/db/migrations && echo 'Migrations removed'",
		"db:seed": "bun run src/scripts/seed.ts",
		"create-admin": "bun run src/scripts/create-admin.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "catalog:",
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/cron": "^1.4.1",
		"@elysiajs/openapi": "^1.4.14",
		"@sinclair/typebox": "catalog:",
		"better-auth": "catalog:",
		"drizzle-orm": "^0.45.1",
		"elysia": "catalog:",
		"logixlysia": "^6.2.0",
		"pg": "catalog:",
		"pino": "^10.3.1"
	},
	"devDependencies": {
		"@types/pg": "catalog:",
		"bun-types": "^1.3.10",
		"drizzle-kit": "^0.31.9",
		"testcontainers": "^11.12.0"
	},
	"module": "src/index.ts",
	"types": "src/types.ts",
	"exports": {
		".": {
			"types": "./src/types.ts",
			"default": "./src/index.ts"
		},
		"./schemas": {
			"default": "./src/lib/schemas/forms/index.ts"
		}
	}
}
