DATABASE_URL=postgresql://pgadmin:password@localhost:5432/bibs-db
# Connection pool tuning (optional — defaults in brackets)
# DATABASE_POOL_MAX=20                  # [20]  max connections in pool
# DATABASE_IDLE_TIMEOUT_MS=30000        # [30s] idle connection reaper
# DATABASE_CONNECTION_TIMEOUT_MS=5000   # [5s]  acquire-connection timeout
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000
PORT=3000

# Mailpit — dev email catcher (web UI: http://localhost:8025)
# MAILPIT_URL=http://localhost:8025   (default; override solo se Mailpit gira altrove)

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=P4ssword!
S3_BUCKET=bibs-images

# Stripe integration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret  (optional, for webhooks in dev)
# STRIPE_DEV_PRICE_ID=price_your_dev_price_id      (optional, for testing)

# CORS - Allowed origins in production (comma-separated)
# In development/test, localhost on any port is automatically allowed.
# Production MUST set NODE_ENV=production, otherwise localhost stays allowed.
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Set to "true" only when the API runs behind a reverse proxy you control that
# sets X-Forwarded-For. Otherwise the rate limiter ignores the header (it is
# client-spoofable) and keys on the socket address.
# TRUST_PROXY=false
