DATABASE_URL=postgresql://pgadmin:password@localhost:5432/bibs-db
# Connection pool tuning (optional — defaults in brackets)
# DATABASE_POOL_MAX=20                  # [20]  max connections in pool
# DATABASE_IDLE_TIMEOUT_MS=30000        # [30s] idle connection reaper
# DATABASE_CONNECTION_TIMEOUT_MS=5000   # [5s]  acquire-connection timeout
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000
PORT=3000

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=P4ssword!
S3_BUCKET=bibs-images

# CORS - Allowed origins in production (comma-separated)
# In development, localhost on any port is automatically allowed
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
