{
	"name": "bibs",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"postinstall": "lefthook install",
		"dev": "concurrently -n api,admin,customer,seller -c blue,green,cyan,magenta \"bun run dev:api\" \"bun run dev:admin\" \"bun run dev:customer\" \"bun run dev:seller\"",
		"dev:api": "bun run --filter @bibs/api dev",
		"dev:customer": "bun run --filter @bibs/customer dev",
		"dev:seller": "bun run --filter @bibs/seller dev",
		"dev:admin": "bun run --filter @bibs/admin dev",
		"test": "bun run --filter @bibs/api test",
		"typecheck": "bun run --filter '*' typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --write .",
		"infra:up": "docker compose up -d",
		"infra:down": "docker compose down",
		"infra:reset": "docker compose down -v",
		"db:generate": "bun run --cwd apps/api db:generate",
		"db:migrate": "bun run --cwd apps/api db:migrate",
		"db:push": "bun run --cwd apps/api db:push",
		"db:studio": "bun run --cwd apps/api db:studio",
		"db:seed": "bun run --cwd apps/api db:seed"
	},
	"catalog": {
		"@aws-sdk/client-s3": "^3.1004.0",
		"@elysiajs/eden": "^1.4.8",
		"@hookform/resolvers": "^5.2.0",
		"@inlang/paraglide-js": "^2.8.0",
		"@sinclair/typebox": "^0.34.48",
		"@t3-oss/env-core": "^0.13.8",
		"@tailwindcss/postcss": "^4.1.18",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/devtools-vite": "^0.3.11",
		"@tanstack/match-sorter-utils": "^8.19.4",
		"@tanstack/react-devtools": "^0.7.0",
		"@tanstack/react-query": "^5.66.5",
		"@tanstack/react-query-devtools": "^5.84.2",
		"@tanstack/react-router": "^1.166.3",
		"@tanstack/react-router-devtools": "^1.166.3",
		"@tanstack/react-router-ssr-query": "^1.166.3",
		"@tanstack/react-start": "1.166.3",
		"@tanstack/react-table": "^8.21.2",
		"@tanstack/router-plugin": "^1.166.3",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/react": "^16.2.0",
		"@types/node": "25.3.5",
		"@types/pg": "8.18.0",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.0.4",
		"better-auth": "1.5.4",
		"elysia": "1.4.27",
		"jsdom": "^27.0.0",
		"lucide-react": "^0.577.0",
		"pg": "^8.20.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-hook-form": "^7.55.0",
		"react-resizable-panels": "^4.7.2",
		"tailwindcss": "^4.1.18",
		"vite": "^7.1.7",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.5",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"concurrently": "^9.2.1",
		"lefthook": "^2.1.3",
		"typescript": "^5.9.3"
	}
}
