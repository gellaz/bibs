# Shadcnblocks API key (Elite lifetime license).
# Used by the shadcn CLI (v3+) and the shadcn MCP server to resolve the
# `@shadcnblocks` namespaced registry declared in `components.json`.
#
# Copy this file to `packages/ui/.env.local` (gitignored) and fill in the key:
#   cp packages/ui/.env.example packages/ui/.env.local
#
# Then either:
#   - run `bunx shadcn@latest add @shadcnblocks/<block>` from `packages/ui/`, or
#   - run it from the repo root and the shadcn CLI will read the `.env.local`
#     adjacent to the `components.json` it's targeting.
SHADCNBLOCKS_API_KEY=
