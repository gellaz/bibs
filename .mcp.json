{
	"mcpServers": {
		"context7": {
			"type": "stdio",
			"command": "bunx",
			"args": ["-y", "@upstash/context7-mcp@latest"]
		},
		"shadcn": {
			"type": "stdio",
			"command": "bunx",
			"args": ["shadcn@latest", "mcp", "--cwd", "./packages/ui"]
		},
		"better-auth": {
			"type": "http",
			"url": "https://mcp.better-auth.com/mcp"
		}
	}
}
